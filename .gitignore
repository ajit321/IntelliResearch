profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, leave it ignored.
#.python-version

# pipenv
#   According to pypa/pipenv#118, it is recommended to include Pipfile.lock in version control.
#   However, if you require to ignore Pipfile.lock, uncomment the following line.
#Lockfile

# poetry
#   Poetry objects to committing poetry.lock in libraries, but strongly suggests it for applications.
#poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/

# venv / virtual environments
#   Do not commit your local dependencies to GitHub.
.env
.venv
.python/
.uv-cache/
.run/
env/
venv/
ENV/
env.bak/
venv.bak/

# Environment variables and secrets
.env
.env.*
.secrets
*.pem
*.key

